Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files and real folders normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # If a request belongs to any real top-level folder app, leave it alone.
  # This protects existing folders such as Finora, hireiq, todo, etc.
  RewriteCond %{DOCUMENT_ROOT}/$1 -d
  RewriteRule ^([^/]+)(/.*)?$ - [L]

  # React/Vite history fallback: every clean app route loads index.html.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "(^\.|\.env|\.ini|\.log|\.sql|\.bak|\.config)$">
  Require all denied
</FilesMatch>
